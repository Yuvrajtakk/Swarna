# ─────────────────────────────────────────────────────────
# Bharat Sanchar AI — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env to Git.
# ─────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────
# Port the Express server listens on (Render sets this automatically)
PORT=5000

# ── MongoDB ─────────────────────────────────────────────
# Full connection string from MongoDB Atlas
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/bharatsanchar?retryWrites=true&w=majority

# ── OpenAI ──────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio (optional — SMS feature) ─────────────────────
# Account SID from https://console.twilio.com
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth Token from https://console.twilio.com
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio phone number (include country code, e.g. +1415XXXXXXX)
TWILIO_PHONE=+1415XXXXXXX

# ── Node environment ─────────────────────────────────────
NODE_ENV=production
